# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=YOUR_SANITY_PROJECT_ID
NEXT_PUBLIC_SANITY_DATASET=production

# OpenAI (used server-side only for NL query embedding)
OPENAI_API_KEY=sk-...

# Railway Python API (PDF score parsing)
SCORE_PARSER_API_URL=https://YOUR_RAILWAY_APP.railway.app
SCORE_PARSER_API_SECRET=your-shared-secret-for-webhook-auth

# Optional: Supabase service_role key (server-side admin operations only)
# NEVER expose this in client-side code or NEXT_PUBLIC_* variables
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
