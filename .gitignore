# ============================================================
# ITE INTELLIGENCE — .gitignore
# Rule: track code, config, and docs. Ignore everything else.
# ============================================================

# --- DATABASE (source of truth — backed up separately) ---
*.db
*.db-shm
*.db-wal

# --- PDF LIBRARY (binary, large — stored in M1 warehouse) ---
*.pdf
*.PDF

# --- DOCX OUTPUT FILES (derived deliverables — regenerable) ---
*.docx
*.DOCX

# --- EXCEL FILES (binary source data — not version-controlled) ---
*.xlsx
*.xls

# --- NODE.JS ---
node_modules/
package-lock.json

# --- PYTHON ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.env
.env.local

# --- PIPELINE RUN LOGS (auto-generated, high churn) ---
00_database/logs/

# --- DERIVED JSON OUTPUTS (regenerable from DB) ---
02_module.2_processor/ite_2018_2019_enriched.json
02_module.2_processor/ite_2018_2019_extracted.json
00_database/readable_db_files/

# --- M3 ANALYST OUTPUTS (derived — regenerable from PDFs + DB) ---
03_module.3_analyst/outputs/

# --- M3 RESIDENT DATA (binary PDFs — already covered by *.pdf, explicit for clarity) ---
03_module.3_analyst/resident_data/

# --- EXTRACTED JSON OUTPUTS (derived — article enrichment outputs, not scripts) ---
extracted_json/

# --- TAGGING BUNDLE DATA FILES (large outputs, not scripts) ---
tagging_bundle/*.csv
tagging_bundle/*.xlsx
tagging_bundle/*.json

# --- LINUX VM / FUSE MOUNT ARTIFACTS (generated by VM filesystem layer) ---
.fuse_hidden*
00_database/db/.fuse_hidden*

# --- M2 BATCH LOGS (auto-generated, high churn — same rule as 00_database/logs/) ---
02_module.2_processor/logs/

# --- COWORK SESSION ARTIFACTS (ghost folder created by Cowork app on session init) ---
\#PROJECT_OVERHAUL/

# --- WINDOWS ARTIFACTS ---
desktop.ini
Thumbs.db
*.lnk

# --- MAC ARTIFACTS (just in case) ---
.DS_Store

# --- CHAT ARCHIVE (Cowork session transcripts — not version-controlled) ---
chat_archive/

# ============================================================
# WHAT IS TRACKED (for reference):
#   All .py scripts (M1/build, M1/maintain, M2, M3, agents)
#   All .js scripts (grandfathered DOCX builders)
#   All .bat files
#   All .md files (BATONs, READMEs, _index.md, architecture docs)
#   key_data_files/session_hy_inserts_v7.json  ← VC gate
#   00_database/schemas/*.json                 ← clinical synonyms, ICD-10 lookup
#   00_database/crosswalk/*.json               ← crosswalk index
#   03_module.3_analyst/scripts/*.json         ← parser config + ABFM reference (M3 config)
#   03_module.3_analyst/docs/*.md, *.json      ← pipeline documentation
#   re-org_guidance/ docs
#   skills_abilities/ reference docs
# ============================================================

# --- BROWSER COOKIES (session credentials --- never commit) ---
key_data_files/cookies/
README_PROJECT.md

key_data_files/browser_profiles/

# --- M1 MAINTAIN STATE FILES (session caches, auth state, run logs) ---
# Convention: leading underscore on filename = transient/derived state, not code.
01_module.1_warehouse/scripts/maintain/_*.json
01_module.1_warehouse/scripts/maintain/_*.txt
01_module.1_warehouse/scripts/maintain/_*.csv
01_module.1_warehouse/scripts/maintain/_*.log

# --- CLAUDE CODE RUNTIME ARTIFACTS (worktrees, lock files, local settings) ---
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json
