{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtractedGuideline",
  "description": "Schema for a fully extracted clinical guideline document",
  "type": "object",
  "required": ["source", "classification", "extraction", "metadata"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["title", "document_type", "publication_year"],
      "properties": {
        "title":            { "type": "string" },
        "organization":     { "type": "string" },
        "document_type":    { "type": "string", "enum": ["chronic_guideline", "acute_protocol", "preventive_guideline", "diagnostic_guideline", "unknown"] },
        "publication_year": { "type": ["integer", "null"] },
        "version_number":   { "type": "string" },
        "doi":              { "type": "string" },
        "file_name":        { "type": "string" }
      }
    },
    "classification": {
      "type": "object",
      "required": ["engine_used", "document_type", "confidence", "signals"],
      "properties": {
        "engine_used":   { "type": "string" },
        "document_type": { "type": "string" },
        "confidence":    { "type": "number", "minimum": 0, "maximum": 1 },
        "signals":       { "type": "array", "items": { "type": "string" } },
        "body_systems":  { "type": "array", "items": { "type": "string" } }
      }
    },
    "extraction": {
      "type": "object",
      "properties": {
        "summary":          { "type": "string" },
        "population": {
          "type": "object",
          "properties": {
            "age_criteria":      { "type": "string" },
            "risk_criteria":     { "type": "string" },
            "disease_definition":{ "type": "string" },
            "exclusions":        { "type": "string" },
            "severity_staging":  { "type": "string" }
          }
        },
        "key_thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "parameter":  { "type": "string" },
              "value":      { "type": "string" },
              "unit":       { "type": "string" },
              "context":    { "type": "string" }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "recommendation": { "type": "string" },
              "strength":       { "type": "string" },
              "evidence_level": { "type": "string" },
              "notes":          { "type": "string" }
            }
          }
        },
        "medications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "drug":       { "type": "string" },
              "dose":       { "type": "string" },
              "indication": { "type": "string" },
              "class":      { "type": "string" }
            }
          }
        },
        "red_flags":         { "type": "array", "items": { "type": "string" } },
        "follow_up":         { "type": "string" },
        "escalation_path":   { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "run_id":          { "type": "string" },
        "extracted_at":    { "type": "string" },
        "engine_version":  { "type": "string" },
        "validation_passed": { "type": "boolean" },
        "validation_warnings": { "type": "array", "items": { "type": "string" } },
        "modules_activated": { "type": "array", "items": { "type": "string" } },
        "raw_text_chars":  { "type": "integer" }
      }
    }
  }
}
